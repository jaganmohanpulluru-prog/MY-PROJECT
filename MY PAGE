<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Nexus | modern web studio</title>
  <!-- Google Fonts + smooth modern reset -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700&display=swap" rel="stylesheet">
  <!-- Font Awesome 6 (free icons) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #fafcff;
      color: #1a2c3e;
      line-height: 1.5;
      scroll-behavior: smooth;
    }

    /* custom container */
    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    /* navigation */
    .navbar {
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid rgba(0,0,0,0.05);
      box-shadow: 0 2px 12px rgba(0,0,0,0.02);
    }

    .nav-container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 2rem;
      max-width: 1400px;
      margin: 0 auto;
    }

    .logo {
      font-size: 1.8rem;
      font-weight: 700;
      background: linear-gradient(135deg, #1E3C72, #2A5298);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      letter-spacing: -0.02em;
    }

    .logo i {
      background: none;
      color: #2A5298;
      margin-right: 6px;
    }

    .nav-links {
      display: flex;
      gap: 2.2rem;
      align-items: center;
    }

    .nav-links a {
      text-decoration: none;
      font-weight: 500;
      color: #2c3e50;
      transition: 0.2s;
      font-size: 1rem;
    }

    .nav-links a:hover, .nav-links a.active {
      color: #2A5298;
    }

    .mobile-menu-btn {
      display: none;
      font-size: 1.6rem;
      cursor: pointer;
      background: none;
      border: none;
      color: #1e2f3e;
    }

    /* Hero section (dynamic) */
    .hero {
      text-align: center;
      padding: 4rem 1.5rem 5rem;
      background: linear-gradient(145deg, #ffffff 0%, #f3f7fe 100%);
    }

    .hero h1 {
      font-size: 3.2rem;
      font-weight: 700;
      background: linear-gradient(125deg, #1E3C72, #1B4F8B);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      margin-bottom: 1.2rem;
      letter-spacing: -0.02em;
    }

    .hero p {
      font-size: 1.2rem;
      max-width: 700px;
      margin: 0 auto;
      color: #4a627a;
    }

    /* card grid & sections */
    .section {
      padding: 4rem 0;
      border-bottom: 1px solid #eef2f8;
    }

    .section-title {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 2rem;
      text-align: center;
      color: #1e2f3e;
    }

    .grid-3 {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
      justify-content: center;
    }

    .card {
      background: white;
      border-radius: 1.5rem;
      padding: 2rem 1.8rem;
      box-shadow: 0 12px 28px rgba(0,0,0,0.05);
      transition: all 0.25s ease;
      flex: 1;
      min-width: 240px;
      border: 1px solid #eef2fa;
      text-align: center;
    }

    .card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 32px rgba(0,0,0,0.08);
    }

    .card i {
      font-size: 2.6rem;
      color: #2A5298;
      margin-bottom: 1rem;
    }

    .card h3 {
      margin-bottom: 0.8rem;
      font-weight: 600;
    }

    .btn {
      display: inline-block;
      background: #1E3C72;
      color: white;
      padding: 0.8rem 1.8rem;
      border-radius: 40px;
      text-decoration: none;
      font-weight: 600;
      transition: 0.2s;
      border: none;
      cursor: pointer;
      font-size: 0.9rem;
    }

    .btn-outline {
      background: transparent;
      border: 1.5px solid #1E3C72;
      color: #1E3C72;
    }

    .btn-outline:hover {
      background: #1E3C72;
      color: white;
    }

    .btn:hover {
      background: #0f2b4f;
      transform: scale(0.97);
    }

    /* contact form */
    .contact-form {
      max-width: 680px;
      margin: 0 auto;
      background: white;
      padding: 2rem 2rem 2.5rem;
      border-radius: 2rem;
      box-shadow: 0 16px 32px rgba(0,0,0,0.04);
    }

    .form-group {
      margin-bottom: 1.3rem;
    }

    input, textarea {
      width: 100%;
      padding: 0.9rem 1.2rem;
      border: 1px solid #cfdfed;
      border-radius: 2rem;
      font-family: inherit;
      font-size: 1rem;
      transition: 0.2s;
      background: #fefefe;
    }

    input:focus, textarea:focus {
      outline: none;
      border-color: #2A5298;
      box-shadow: 0 0 0 3px rgba(42,82,152,0.1);
    }

    textarea {
      border-radius: 1.5rem;
      resize: vertical;
    }

    .submit-status {
      margin-top: 1rem;
      font-size: 0.9rem;
      text-align: center;
    }

    footer {
      background: #0f172a;
      color: #cbd5e6;
      padding: 2.5rem 0;
      text-align: center;
    }

    .footer-links {
      display: flex;
      justify-content: center;
      gap: 2rem;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
    }

    .footer-links a {
      color: #b9c8f0;
      text-decoration: none;
    }

    /* dynamic pages content via js / show/hide sections */
    .page {
      display: none;
      animation: fadeIn 0.35s ease;
    }

    .active-page {
      display: block;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px);}
      to { opacity: 1; transform: translateY(0);}
    }

    /* responsive */
    @media (max-width: 780px) {
      .nav-links {
        display: none;
        flex-direction: column;
        background: white;
        position: absolute;
        top: 70px;
        left: 0;
        width: 100%;
        padding: 1.8rem;
        box-shadow: 0 20px 30px rgba(0,0,0,0.1);
        gap: 1.3rem;
        border-radius: 0 0 1.5rem 1.5rem;
      }
      .nav-links.show {
        display: flex;
      }
      .mobile-menu-btn {
        display: block;
      }
      .container {
        padding: 0 1.2rem;
      }
      .hero h1 {
        font-size: 2.4rem;
      }
    }

    /* demo alert for contact (just simulation) */
    .toast-msg {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      background: #1e2f3e;
      color: white;
      padding: 12px 24px;
      border-radius: 60px;
      font-size: 0.9rem;
      z-index: 200;
      box-shadow: 0 6px 14px rgba(0,0,0,0.15);
      transition: opacity 0.2s;
      pointer-events: none;
    }
  </style>
</head>
<body>

<nav class="navbar">
  <div class="nav-container">
    <div class="logo">
      <i class="fas fa-cube"></i> Nexus
    </div>
    <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Menu">
      <i class="fas fa-bars"></i>
    </button>
    <div class="nav-links" id="navLinks">
      <a href="#" data-page="home" class="nav-link active">Home</a>
      <a href="#" data-page="services" class="nav-link">Services</a>
      <a href="#" data-page="contact" class="nav-link">Contact</a>
    </div>
  </div>
</nav>

<main>
  <!-- HOME PAGE -->
  <div id="home-page" class="page active-page">
    <div class="hero">
      <div class="container">
        <h1>Crafting digital experiences <br>that elevate brands</h1>
        <p>We build modern, responsive websites and web applications tailored to your vision.</p>
        <div style="margin-top: 2rem;">
          <a href="#" data-page="contact" class="btn" id="heroCtaBtn">Start a project <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
    </div>
    <div class="section">
      <div class="container">
        <h2 class="section-title">Why work with us</h2>
        <div class="grid-3">
          <div class="card"><i class="fas fa-code"></i><h3>Clean Code</h3><p>Semantic, maintainable HTML/CSS/JS with performance in mind.</p></div>
          <div class="card"><i class="fas fa-mobile-alt"></i><h3>Fully Responsive</h3><p>Flawless experience on all devices, from mobile to 4K displays.</p></div>
          <div class="card"><i class="fas fa-rocket"></i><h3>Fast & Modern</h3><p>Optimized architecture, smooth interactions and modern UI.</p></div>
        </div>
      </div>
    </div>
    <div class="section" style="background: #f8fafd;">
      <div class="container">
        <h2 class="section-title">Latest projects showcase</h2>
        <div class="grid-3">
          <div class="card"><i class="fas fa-store"></i><h3>E‑commerce Suite</h3><p>Full product catalog with dynamic cart simulation.</p></div>
          <div class="card"><i class="fas fa-chart-line"></i><h3>Analytics Dashboard</h3><p>Real-time insights, charts and data visualization.</p></div>
          <div class="card"><i class="fas fa-gem"></i><h3>Brand Portfolio</h3><p>Creative agency site with immersive storytelling.</p></div>
        </div>
      </div>
    </div>
  </div>

  <!-- SERVICES PAGE -->
  <div id="services-page" class="page">
    <div class="hero" style="padding: 3rem 1.5rem; background: #ffffff;">
      <div class="container">
        <h1>Our Services</h1>
        <p>Tailored solutions to bring your digital presence to the next level.</p>
      </div>
    </div>
    <div class="section">
      <div class="container">
        <div class="grid-3" style="gap: 2rem;">
          <div class="card"><i class="fas fa-palette"></i><h3>UI/UX Design</h3><p>Wireframes, prototypes and user-centered interfaces that convert.</p></div>
          <div class="card"><i class="fab fa-js"></i><h3>Front-end Dev</h3><p>Interactive SPAs, animations and component-driven architecture.</p></div>
          <div class="card"><i class="fas fa-database"></i><h3>Backend Integration</h3><p>APIs, databases, authentication — full-stack capabilities.</p></div>
          <div class="card"><i class="fas fa-magnifying-glass-chart"></i><h3>SEO & Performance</h3><p>Lightning fast load times, semantic markup, optimal ranking.</p></div>
          <div class="card"><i class="fas fa-cart-shopping"></i><h3>E-commerce Solutions</h3><p>Secure payment flows, product management, and more.</p></div>
          <div class="card"><i class="fas fa-headset"></i><h3>Support & Maintenance</h3><p>24/7 monitoring, updates and technical assistance.</p></div>
        </div>
      </div>
    </div>
    <div class="section" style="background: #f8fafd; text-align: center;">
      <div class="container">
        <h2 class="section-title">Need a custom solution?</h2>
        <a href="#" data-page="contact" class="btn" style="margin-top: 0.5rem;">Get a free quote →</a>
      </div>
    </div>
  </div>

  <!-- CONTACT PAGE -->
  <div id="contact-page" class="page">
    <div class="hero" style="padding: 2.5rem 1.5rem;">
      <div class="container">
        <h1>Let's talk</h1>
        <p>Have a project in mind? Fill out the form and we’ll get back within 24h.</p>
      </div>
    </div>
    <div class="section" style="padding-top: 1rem;">
      <div class="container">
        <div class="contact-form">
          <form id="contactForm">
            <div class="form-group">
              <input type="text" id="name" placeholder="Full name" required>
            </div>
            <div class="form-group">
              <input type="email" id="email" placeholder="Email address" required>
            </div>
            <div class="form-group">
              <textarea rows="4" id="message" placeholder="Tell us about your website idea..." required></textarea>
            </div>
            <button type="submit" class="btn" style="width: 100%; justify-content: center;">Send Message <i class="fas fa-paper-plane"></i></button>
            <div id="formStatus" class="submit-status"></div>
          </form>
        </div>
      </div>
    </div>
    <div style="text-align: center; padding: 2rem 0 3rem;">
      <i class="fas fa-envelope" style="margin-right: 0.5rem; color:#2A5298;"></i> hello@nexus-studio.dev &nbsp;|&nbsp;
      <i class="fas fa-phone-alt"></i> +1 (555) 789-2341
    </div>
  </div>
</main>

<footer>
  <div class="container">
    <div class="footer-links">
      <a href="#" data-page="home">Home</a>
      <a href="#" data-page="services">Services</a>
      <a href="#" data-page="contact">Contact</a>
      <a href="#">Privacy</a>
      <a href="#">Terms</a>
    </div>
    <p>© 2025 Nexus Studio — built with HTML, CSS & vanilla JS. All concepts simulated.</p>
    <p style="margin-top: 0.6rem; font-size: 0.8rem;">✨ Fully responsive • modern design • dynamic SPA-like navigation</p>
  </div>
</footer>

<script>
  (function() {
    // ---------- SPA style navigation (routing without reload) ----------
    const pages = {
      home: document.getElementById('home-page'),
      services: document.getElementById('services-page'),
      contact: document.getElementById('contact-page')
    };
    
    const navLinks = document.querySelectorAll('.nav-link');
    const allPageTrigger = document.querySelectorAll('[data-page]'); // includes footer links & cta buttons

    function setActivePage(pageId) {
      // hide all pages
      Object.values(pages).forEach(page => {
        if(page) page.classList.remove('active-page');
      });
      const activePage = pages[pageId];
      if(activePage) activePage.classList.add('active-page');
      
      // update active class on nav menu items
      navLinks.forEach(link => {
        const linkPage = link.getAttribute('data-page');
        if(linkPage === pageId) {
          link.classList.add('active');
        } else {
          link.classList.remove('active');
        }
      });
      
      // update browser hash without scrolling
      if (window.location.hash !== `#${pageId}`) {
        history.pushState(null, '', `#${pageId}`);
      }
      // close mobile menu if open
      const mobileMenu = document.getElementById('navLinks');
      if(mobileMenu.classList.contains('show')) {
        mobileMenu.classList.remove('show');
      }
    }
    
    // Handler for any element with data-page attribute (navigation)
    function onNavigate(e) {
      const target = e.currentTarget;
      const page = target.getAttribute('data-page');
      if(page && pages[page]) {
        e.preventDefault();
        setActivePage(page);
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    }
    
    // Attach to all elements that have data-page attributes (including nav, footer, extra buttons)
    allPageTrigger.forEach(el => {
      el.addEventListener('click', onNavigate);
    });
    
    // manually attach to hero button (already has data-page="contact", but to be safe double-check)
    const heroBtn = document.getElementById('heroCtaBtn');
    if(heroBtn) heroBtn.addEventListener('click', onNavigate);
    
    // initial route from URL hash
    function handleHashChange() {
      let hash = window.location.hash.substring(1);
      if(hash && pages[hash]) {
        setActivePage(hash);
      } else {
        // default to home
        setActivePage('home');
      }
    }
    
    window.addEventListener('hashchange', handleHashChange);
    handleHashChange();  // set initial view
    
    // Mobile menu toggle
    const mobileBtn = document.getElementById('mobileMenuBtn');
    const navMenu = document.getElementById('navLinks');
    if(mobileBtn && navMenu) {
      mobileBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        navMenu.classList.toggle('show');
      });
      // close when clicking a link inside mobile menu
      const menuLinks = navMenu.querySelectorAll('a');
      menuLinks.forEach(link => {
        link.addEventListener('click', () => {
          navMenu.classList.remove('show');
        });
      });
    }
    
    // ---------------- Contact form simulation (no backend) ----------------
    const contactForm = document.getElementById('contactForm');
    const formStatus = document.getElementById('formStatus');
    
    if(contactForm) {
      contactForm.addEventListener('submit', function(e) {
        e.preventDefault();
        const name = document.getElementById('name').value.trim();
        const email = document.getElementById('email').value.trim();
        const message = document.getElementById('message').value.trim();
        
        if(!name || !email || !message) {
          formStatus.innerHTML = '<span style="color:#c7362b;">❌ Please fill all fields.</span>';
          return;
        }
        if(!email.includes('@') || !email.includes('.')) {
          formStatus.innerHTML = '<span style="color:#c7362b;">⚠️ Enter a valid email address.</span>';
          return;
        }
        
        // simulate sending
        formStatus.innerHTML = '<span style="color:#2A5298;">⏳ Sending message...</span>';
        setTimeout(() => {
          // demo success message, store in localStorage just for playful reminder
          try {
            const submissions = JSON.parse(localStorage.getItem('demo_contact_submissions') || '[]');
            submissions.push({ name, email, message, date: new Date().toISOString() });
            localStorage.setItem('demo_contact_submissions', JSON.stringify(submissions));
          } catch(e) { /* ignore */}
          formStatus.innerHTML = '<span style="color:#2b7042;">✅ Thanks! Our team will reach out shortly. (demo)</span>';
          contactForm.reset();
          // show floating message (optional extra toast)
          showToastMessage('Message sent! (simulated)');
          setTimeout(() => {
            if(formStatus) formStatus.innerHTML = '';
          }, 4000);
        }, 800);
      });
    }
    
    // toast helper
    function showToastMessage(msg) {
      let toast = document.querySelector('.toast-msg');
      if(toast) toast.remove();
      const div = document.createElement('div');
      div.className = 'toast-msg';
      div.textContent = msg;
      document.body.appendChild(div);
      setTimeout(() => {
        if(div) div.style.opacity = '0';
        setTimeout(() => div.remove(), 500);
      }, 2800);
    }
    
    // additional small dynamic effect: highlight active section but already done.
    // also handle if any external link prevention?
    
    // ensure images & interactions are sterile: everything works on 100% client-side
    console.log('Website fully loaded — dynamic navigation & contact simulation ready');
  })();
</script>
</body>
</html>
